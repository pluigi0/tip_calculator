<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Tip Calculator</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #f5f0e8;
      --surface: #ffffff;
      --text: #1a1a1a;
      --muted: #7a7570;
      --accent: #2d6a4f;
      --accent-light: #e8f5ee;
      --accent-dark: #1b4332;
      --border: #e0d9ce;
      --radius: 16px;
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem 1rem;
    }

    .card {
      background: var(--surface);
      border-radius: var(--radius);
      border: 1px solid var(--border);
      padding: 2rem;
      width: 100%;
      max-width: 420px;
    }

    h1 {
      font-family: 'DM Serif Display', serif;
      font-size: 1.8rem;
      font-weight: 400;
      letter-spacing: -0.5px;
      margin-bottom: 0.25rem;
    }

    .subtitle {
      font-size: 0.85rem;
      color: var(--muted);
      margin-bottom: 2rem;
    }

    .field {
      margin-bottom: 1.25rem;
    }

    label {
      display: block;
      font-size: 0.8rem;
      font-weight: 500;
      color: var(--muted);
      letter-spacing: 0.5px;
      text-transform: uppercase;
      margin-bottom: 0.5rem;
    }

    input[type="number"] {
      width: 100%;
      padding: 0.75rem 1rem;
      border: 1px solid var(--border);
      border-radius: 10px;
      font-family: 'DM Sans', sans-serif;
      font-size: 1rem;
      color: var(--text);
      background: var(--bg);
      outline: none;
      transition: border-color 0.2s;
    }

    input[type="number"]:focus {
      border-color: var(--accent);
    }

    input[type="number"]::placeholder {
      color: #c0bbb5;
    }

    .tip-buttons {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 8px;
      margin-bottom: 1.25rem;
    }

    .tip-btn {
      padding: 0.6rem 0.25rem;
      border: 1px solid var(--border);
      border-radius: 10px;
      background: var(--bg);
      font-family: 'DM Sans', sans-serif;
      font-size: 0.9rem;
      font-weight: 500;
      color: var(--muted);
      cursor: pointer;
      transition: all 0.15s;
    }

    .tip-btn:hover {
      border-color: var(--accent);
      color: var(--accent);
    }

    .tip-btn.active {
      background: var(--accent);
      border-color: var(--accent);
      color: #fff;
    }

    .custom-tip-wrap {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 1.25rem;
    }

    .custom-tip-wrap label {
      margin: 0;
      white-space: nowrap;
    }

    .custom-tip-wrap input {
      flex: 1;
    }

    .results {
      background: var(--accent-dark);
      border-radius: var(--radius);
      padding: 1.5rem;
      margin-top: 1.5rem;
      color: #fff;
    }

    .result-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.5rem 0;
    }

    .result-row + .result-row {
      border-top: 1px solid rgba(255,255,255,0.12);
    }

    .result-label {
      font-size: 0.82rem;
      opacity: 0.7;
      letter-spacing: 0.3px;
    }

    .result-value {
      font-size: 1.15rem;
      font-weight: 500;
    }

    .result-row.total .result-label {
      font-size: 0.9rem;
      opacity: 1;
      font-weight: 500;
    }

    .result-row.total .result-value {
      font-size: 1.45rem;
      font-family: 'DM Serif Display', serif;
      font-weight: 400;
    }

    .per-person {
      background: rgba(255,255,255,0.1);
      border-radius: 10px;
      padding: 0.75rem 1rem;
      margin-top: 1rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .per-person .result-label {
      opacity: 1;
      font-size: 0.85rem;
    }

    .per-person .result-value {
      font-size: 1.25rem;
    }

    .reset-btn {
      width: 100%;
      margin-top: 1.25rem;
      padding: 0.75rem;
      background: transparent;
      border: 1px solid var(--border);
      border-radius: 10px;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.9rem;
      color: var(--muted);
      cursor: pointer;
      transition: all 0.15s;
    }

    .reset-btn:hover {
      border-color: var(--accent);
      color: var(--accent);
    }

    input::-webkit-outer-spin-button,
    input::-webkit-inner-spin-button { -webkit-appearance: none; }
    input[type=number] { -moz-appearance: textfield; }
  </style>
</head>
<body>
  <div class="card">
    <h1>Tip Calculator</h1>
    <p class="subtitle">Split the bill with ease</p>

    <div class="field">
      <label>Bill Amount ($)</label>
      <input type="number" id="bill" placeholder="0.00" min="0" step="0.01" />
    </div>

    <div class="field">
      <label>Select Tip</label>
      <div class="tip-buttons">
        <button class="tip-btn" data-tip="10">10%</button>
        <button class="tip-btn active" data-tip="15">15%</button>
        <button class="tip-btn" data-tip="20">20%</button>
        <button class="tip-btn" data-tip="25">25%</button>
      </div>
    </div>

    <div class="custom-tip-wrap">
      <label>Custom %</label>
      <input type="number" id="custom-tip" placeholder="e.g. 18" min="0" max="100" />
    </div>

    <div class="field">
      <label>Number of People</label>
      <input type="number" id="people" placeholder="1" min="1" value="1" />
    </div>

    <div class="results">
      <div class="result-row">
        <span class="result-label">Bill</span>
        <span class="result-value" id="out-bill">$0.00</span>
      </div>
      <div class="result-row">
        <span class="result-label">Tip (<span id="out-tip-pct">15</span>%)</span>
        <span class="result-value" id="out-tip">$0.00</span>
      </div>
      <div class="result-row total">
        <span class="result-label">Total</span>
        <span class="result-value" id="out-total">$0.00</span>
      </div>
      <div class="per-person">
        <span class="result-label">Per person</span>
        <span class="result-value" id="out-per">$0.00</span>
      </div>
    </div>

    <button class="reset-btn" id="reset">Reset</button>
  </div>

  <script>
    let selectedTip = 15;

    const billInput    = document.getElementById('bill');
    const customTip    = document.getElementById('custom-tip');
    const peopleInput  = document.getElementById('people');
    const tipBtns      = document.querySelectorAll('.tip-btn');

    const outBill    = document.getElementById('out-bill');
    const outTipPct  = document.getElementById('out-tip-pct');
    const outTip     = document.getElementById('out-tip');
    const outTotal   = document.getElementById('out-total');
    const outPer     = document.getElementById('out-per');

    function fmt(n) {
      return '$' + n.toFixed(2);
    }

    function calculate() {
      const bill    = parseFloat(billInput.value) || 0;
      const people  = Math.max(1, parseInt(peopleInput.value) || 1);
      const tip     = selectedTip;
      const tipAmt  = bill * (tip / 100);
      const total   = bill + tipAmt;

      outBill.textContent   = fmt(bill);
      outTipPct.textContent = tip;
      outTip.textContent    = fmt(tipAmt);
      outTotal.textContent  = fmt(total);
      outPer.textContent    = fmt(total / people);
    }

    tipBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        tipBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        selectedTip = parseInt(btn.dataset.tip);
        customTip.value = '';
        calculate();
      });
    });

    customTip.addEventListener('input', () => {
      const val = parseFloat(customTip.value);
      if (!isNaN(val) && val >= 0) {
        tipBtns.forEach(b => b.classList.remove('active'));
        selectedTip = val;
        calculate();
      }
    });

    billInput.addEventListener('input', calculate);
    peopleInput.addEventListener('input', calculate);

    document.getElementById('reset').addEventListener('click', () => {
      billInput.value   = '';
      customTip.value   = '';
      peopleInput.value = '1';
      selectedTip       = 15;
      tipBtns.forEach(b => b.classList.remove('active'));
      document.querySelector('[data-tip="15"]').classList.add('active');
      calculate();
    });

    calculate();
  </script>
</body>
</html>
